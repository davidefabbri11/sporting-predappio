---
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import SeasonSwitcher from '../../../components/SeasonSwitcher.astro';
import YouthCategoryCard from '../../../components/YouthCategoryCard.astro';
import { getAllSeasons, getSeasonLabel, getSeasonManifest, getYouthRoster, getYouthStaff, isValidSeason } from '../../../lib/seasons';

export function getStaticPaths() {
  const seasons = getAllSeasons();
  return seasons.map(s => ({ params: { season: s.id } }));
}

const { season: seasonId } = Astro.params;

if (!isValidSeason(seasonId)) {
  return Astro.redirect('/settore-giovanile');
}

const seasonLabel = getSeasonLabel(seasonId);
const manifest = getSeasonManifest(seasonId);
const categories = manifest?.giovanili ?? [];
const responsabile = manifest?.responsabileGiovanili;

const categoriesWithInfo = categories.map(cat => {
  const staff = getYouthStaff(seasonId, cat.id);
  const coach = staff.find(s => s.ruolo === 'Allenatore');
  return {
    ...cat,
    playerCount: getYouthRoster(seasonId, cat.id).length,
    coach: coach?.nome,
  };
});
---

<Layout title={`Settore Giovanile ${seasonLabel} | Sporting Predappio`} description={`Il settore giovanile dell'A.S.D. Sporting Predappio - Stagione ${seasonLabel}.`}>
  <PageHeader title="Settore Giovanile" subtitle={`Stagione ${seasonLabel}`}>
    <SeasonSwitcher currentSeasonId={seasonId} basePath="/settore-giovanile" defaultPath="/settore-giovanile" />
  </PageHeader>

  <!-- Responsabile -->
  {responsabile && (
    <section class="py-8 bg-white border-b border-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-center gap-3 reveal">
          <div class="w-10 h-10 bg-gradient-to-br from-azzurro-500 to-azzurro-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-azzurro-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-gray-400 uppercase tracking-wider font-semibold">{responsabile.ruolo}</p>
            <p class="font-heading font-bold text-lg text-gray-900 tracking-wide">{responsabile.nome}</p>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="py-20 bg-[#fafbfc]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      {categories.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal stagger-children">
          {categoriesWithInfo.map(cat => (
            <YouthCategoryCard
              id={cat.id}
              nome={cat.nome}
              annate={cat.annate}
              seasonId={seasonId}
              playerCount={cat.playerCount}
              coach={cat.coach}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <h3 class="font-heading font-bold text-2xl text-gray-900 mb-3">Settore giovanile in costruzione</h3>
          <p class="text-gray-400">Le categorie giovanili verranno aggiunte presto.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
