---
import Layout from '../layouts/Layout.astro';
import StaffCard from '../components/StaffCard.astro';
import club from '../data/club.json';

const dirigenti = club.dirigenti;
---

<Layout title="Chi Siamo | Sporting Predappio" description="Scopri la storia dell'A.S.D. Sporting Predappio, fondata nel 2015 a Predappio (FC).">
  <!-- Page Header -->
  <section class="relative overflow-hidden -mt-[72px]">
    <div class="absolute inset-0 mesh-gradient"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,rgba(8,37,54,0.5)_100%)]"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-28 md:py-32 text-center">
      <h1 class="font-heading font-extrabold text-5xl md:text-6xl lg:text-7xl text-white mb-4 tracking-[0.1em]">Chi Siamo</h1>
      <p class="text-azzurro-200/80 text-lg">La storia e i valori dello Sporting Predappio</p>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <div class="h-px bg-gradient-to-r from-transparent via-azzurro-400/30 to-transparent"></div>
      <div class="h-16 bg-gradient-to-t from-white to-transparent"></div>
    </div>
  </section>

  <!-- Storia -->
  <section class="py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8 reveal">
        <div class="w-10 h-10 bg-gradient-to-br from-azzurro-500 to-azzurro-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-azzurro-500/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <h2 class="font-heading font-extrabold text-2xl md:text-3xl tracking-wide">La Nostra Storia</h2>
      </div>
      <p class="text-gray-500 leading-relaxed text-lg mb-10 reveal">{club.storia}</p>

      <!-- Timeline -->
      <div class="relative pl-10 border-l-2 border-azzurro-100 space-y-5 reveal">
        {club.storico_categorie.map((item: { stagione: string; categoria: string }, i: number) => (
          <div class="relative group">
            <div class="absolute -left-[29px] w-4 h-4 bg-gradient-to-br from-azzurro-400 to-azzurro-600 rounded-full border-4 border-white shadow-sm group-hover:scale-125 transition-transform duration-300"></div>
            <div class="bg-gray-50 rounded-xl p-4 border border-gray-100 hover:shadow-md hover:border-azzurro-100 transition-all duration-300">
              <span class="text-sm font-bold text-azzurro-500">{item.stagione}</span>
              <p class="font-heading font-bold text-gray-900 tracking-wide">{item.categoria}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stadio -->
  <section class="py-20 bg-[#fafbfc] relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div class="reveal">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 bg-gradient-to-br from-azzurro-500 to-azzurro-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-azzurro-500/20">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="font-heading font-extrabold text-2xl md:text-3xl tracking-wide">Il Nostro Stadio</h2>
          </div>
          <h3 class="font-heading font-bold text-xl text-azzurro-600 mb-3">{club.stadio.nome}</h3>
          <p class="text-gray-500 mb-2">{club.stadio.indirizzo}</p>
          <p class="text-gray-400 text-sm mb-8">Il campo di casa dello Sporting Predappio, dove ogni domenica la squadra scende in campo con passione e determinazione.</p>

          <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-sm">
            <h4 class="font-heading font-bold text-sm text-gray-900 mb-2 tracking-wide">Sede Sociale</h4>
            <p class="text-sm text-gray-500">{club.sede.indirizzo}</p>
            <p class="text-sm text-gray-500 mt-1">Tel: {club.telefono}</p>
          </div>
        </div>

        <div class="reveal">
          <div class="rounded-3xl overflow-hidden shadow-2xl shadow-gray-200/60 border border-gray-100">
            <img
              src="/images/stadio.jpg"
              alt={club.stadio.nome}
              class="w-full h-80 object-cover object-bottom"
              loading="lazy"
            />
          </div>
          <a
            href={`https://www.openstreetmap.org/?mlat=${club.stadio.coordinate.lat}&mlon=${club.stadio.coordinate.lng}#map=17/${club.stadio.coordinate.lat}/${club.stadio.coordinate.lng}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-azzurro-500 hover:text-azzurro-600 text-sm font-semibold mt-4 transition-colors duration-300"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Vedi su mappa
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Presidente e Dirigenza -->
  <section class="py-20 bg-white relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8 reveal">
        <div class="w-10 h-10 bg-gradient-to-br from-azzurro-500 to-azzurro-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-azzurro-500/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h2 class="font-heading font-extrabold text-2xl md:text-3xl tracking-wide">Dirigenza</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 reveal stagger-children">
        {dirigenti.map(d => (
          <StaffCard {...d} />
        ))}
      </div>
    </div>
  </section>

  <!-- Colori Sociali -->
  <section class="py-20 bg-[#fafbfc] relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center reveal">
      <h2 class="font-heading font-extrabold text-2xl md:text-3xl mb-8 tracking-wide">I Nostri Colori</h2>
      <div class="flex justify-center gap-8">
        <div class="text-center group">
          <div class="w-24 h-24 bg-white border-2 border-gray-200 rounded-3xl shadow-lg shadow-gray-100 mx-auto mb-3 group-hover:shadow-xl group-hover:-translate-y-1 transition-all duration-300"></div>
          <span class="text-sm font-semibold text-gray-500">Bianco</span>
        </div>
        <div class="text-center group">
          <div class="w-24 h-24 bg-gradient-to-br from-azzurro-400 to-azzurro-600 rounded-3xl shadow-lg shadow-azzurro-200 mx-auto mb-3 group-hover:shadow-xl group-hover:shadow-azzurro-300 group-hover:-translate-y-1 transition-all duration-300"></div>
          <span class="text-sm font-semibold text-gray-500">Azzurro</span>
        </div>
      </div>
    </div>
  </section>
</Layout>
