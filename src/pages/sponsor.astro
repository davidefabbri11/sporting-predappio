---
import Layout from '../layouts/Layout.astro';
import sponsors from '../data/sponsors.json';

const mainSponsors = sponsors.filter(s => s.tier === 'main');
const technicalPartners = sponsors.filter(s => s.tier === 'technical');
---

<Layout title="Sponsor | Sporting Predappio" description="I nostri sponsor e partner che supportano l'A.S.D. Sporting Predappio.">
  <!-- Page Header -->
  <section class="relative overflow-hidden -mt-[72px]">
    <div class="absolute inset-0 mesh-gradient"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,rgba(8,37,54,0.5)_100%)]"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-28 md:py-32 text-center">
      <h1 class="font-heading font-extrabold text-5xl md:text-6xl lg:text-7xl text-white mb-4 tracking-[0.1em]">Sponsor</h1>
      <p class="text-azzurro-200/80 text-lg">I partner che credono nel nostro progetto</p>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <div class="h-px bg-gradient-to-r from-transparent via-azzurro-400/30 to-transparent"></div>
      <div class="h-16 bg-gradient-to-t from-white to-transparent"></div>
    </div>
  </section>

  <!-- Sponsor Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 reveal">
        <span class="inline-flex items-center gap-2 bg-oro-50 text-oro-600 text-xs font-bold uppercase tracking-[0.15em] px-4 py-2 rounded-full mb-4 border border-oro-200">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
          </svg>
          Grazie
        </span>
        <h2 class="font-heading font-extrabold text-4xl md:text-5xl text-gray-900 mb-4">I Nostri Sponsor</h2>
        <p class="text-gray-500 max-w-2xl mx-auto text-lg">Un ringraziamento speciale a chi supporta la nostra squadra e il nostro settore giovanile.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal stagger-children">
        {mainSponsors.map(sponsor => (
          <a
            href={sponsor.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group bg-[#fafbfc] rounded-3xl p-8 border border-gray-100 hover:shadow-xl hover:border-oro-200/50 hover:-translate-y-1 transition-all duration-500 flex flex-col items-center text-center"
          >
            <div class="w-full h-32 flex items-center justify-center mb-6 rounded-2xl bg-white border border-gray-50 group-hover:border-oro-100 transition-all duration-300 p-4">
              <img
                src={sponsor.logo}
                alt={sponsor.nome}
                class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <h3 class="font-heading font-bold text-lg text-gray-900 group-hover:text-azzurro-600 transition-colors duration-300">{sponsor.nome}</h3>
            <span class="inline-flex items-center gap-1 text-azzurro-500 text-sm font-semibold mt-3 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0">
              Visita il sito
              <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Tecnico -->
  {technicalPartners.length > 0 && (
    <section class="py-20 bg-[#fafbfc] relative">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12 reveal">
          <span class="inline-flex items-center gap-2 bg-azzurro-50 text-azzurro-600 text-xs font-bold uppercase tracking-[0.15em] px-4 py-2 rounded-full mb-4 border border-azzurro-100">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
            Partner Tecnico
          </span>
          <h2 class="font-heading font-extrabold text-4xl md:text-5xl text-gray-900">Partner Tecnico</h2>
        </div>
        <div class="flex justify-center reveal">
          {technicalPartners.map(partner => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-white rounded-3xl p-10 border border-gray-100 hover:shadow-xl hover:border-azzurro-200/50 hover:-translate-y-1 transition-all duration-500 flex flex-col items-center text-center max-w-sm w-full"
            >
              <div class="w-full h-36 flex items-center justify-center mb-6 rounded-2xl bg-[#fafbfc] border border-gray-50 group-hover:border-azzurro-100 transition-all duration-300 p-6">
                <img
                  src={partner.logo}
                  alt={partner.nome}
                  class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <h3 class="font-heading font-bold text-xl text-gray-900 group-hover:text-azzurro-600 transition-colors duration-300">{partner.nome}</h3>
              <span class="inline-flex items-center gap-1 text-azzurro-500 text-sm font-semibold mt-3 opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-1 group-hover:translate-y-0">
                Visita il sito
                <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
            </a>
            {partner.shopUrl && (
              <a
                href={partner.shopUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center gap-2 bg-azzurro-500 text-white px-6 py-3 rounded-xl font-semibold text-sm hover:bg-azzurro-400 hover:shadow-lg hover:shadow-azzurro-500/20 transition-all duration-300 hover:-translate-y-0.5"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                Vai allo Shop
              </a>
            )}
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-20 bg-[#fafbfc] relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center reveal">
      <div class="bg-gradient-to-br from-azzurro-900 via-azzurro-950 to-gray-900 rounded-3xl p-10 md:p-14 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-azzurro-500/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-oro-500/5 rounded-full translate-y-1/2 -translate-x-1/2"></div>
        <div class="relative">
          <h3 class="font-heading font-bold text-3xl md:text-4xl mb-4 tracking-wide">Diventa Sponsor</h3>
          <p class="text-azzurro-100/70 mb-8 max-w-lg mx-auto">Vuoi supportare lo Sporting Predappio? Contattaci per scoprire le opportunità di partnership.</p>
          <a href="/contatti" class="inline-flex items-center gap-2 bg-oro-500 text-white px-8 py-4 rounded-xl font-bold hover:bg-oro-400 hover:shadow-xl hover:shadow-oro-500/20 transition-all duration-300 hover:-translate-y-0.5">
            Contattaci
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
