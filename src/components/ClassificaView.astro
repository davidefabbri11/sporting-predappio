---
import type { ClassificaData } from '../lib/seasons';

interface Props {
  data: ClassificaData;
}

const { data } = Astro.props;
const TEAM_NAME = 'Sporting Predappio';
const totalTeams = data.classifica.length;

// Zone: 1° promossa, 2°-5° playoff, 12°-13° playout, 14° retrocessa
function getZone(pos: number) {
  if (pos === 1) return 'promozione';
  if (pos >= 2 && pos <= 5) return 'playoff';
  if (pos >= totalTeams - 2 && pos <= totalTeams - 1) return 'playout';
  if (pos === totalTeams) return 'retrocessione';
  return null;
}

function getZoneColor(pos: number) {
  const zone = getZone(pos);
  if (zone === 'promozione') return 'border-l-4 border-l-green-500';
  if (zone === 'playoff') return 'border-l-4 border-l-azzurro-400';
  if (zone === 'playout') return 'border-l-4 border-l-orange-400';
  if (zone === 'retrocessione') return 'border-l-4 border-l-red-500';
  return 'border-l-4 border-l-transparent';
}

function getPosColor(pos: number) {
  const zone = getZone(pos);
  if (zone === 'promozione') return 'text-green-600';
  if (zone === 'playoff') return 'text-azzurro-500';
  if (zone === 'playout') return 'text-orange-500';
  if (zone === 'retrocessione') return 'text-red-500';
  return 'text-gray-400';
}
---

<section class="py-16 bg-white relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Classifica -->
      <div class="lg:col-span-2 reveal">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-gradient-to-br from-azzurro-500 to-azzurro-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-azzurro-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <div>
            <h2 class="font-heading font-extrabold text-2xl md:text-3xl text-gray-900 tracking-wide">Classifica</h2>
            <p class="text-gray-400 text-sm">Giornata {data.giornata}</p>
          </div>
        </div>

        <div class="bg-[#fafbfc] rounded-2xl border border-gray-100 overflow-hidden">
          <!-- Header -->
          <div class="grid grid-cols-[2rem_1fr_2.5rem_2.5rem_2.5rem_2.5rem_2.5rem_2.5rem_2.5rem] md:grid-cols-[2.5rem_1fr_3rem_3rem_3rem_3rem_3rem_3rem_3rem] gap-0 px-4 py-3 bg-azzurro-950 text-white text-xs font-bold uppercase tracking-wider">
            <span class="text-center">#</span>
            <span>Squadra</span>
            <span class="text-center">Pt</span>
            <span class="text-center hidden md:block">PG</span>
            <span class="text-center">V</span>
            <span class="text-center">N</span>
            <span class="text-center">P</span>
            <span class="text-center hidden md:block">GF</span>
            <span class="text-center hidden md:block">GS</span>
          </div>

          <!-- Rows -->
          {data.classifica.map((team, i) => {
            const isUs = team.squadra === TEAM_NAME;
            return (
              <div class:list={[
                'grid grid-cols-[2rem_1fr_2.5rem_2.5rem_2.5rem_2.5rem_2.5rem_2.5rem_2.5rem] md:grid-cols-[2.5rem_1fr_3rem_3rem_3rem_3rem_3rem_3rem_3rem] gap-0 px-4 py-2.5 text-sm border-b border-gray-100 last:border-0 transition-colors duration-200',
                isUs ? 'bg-azzurro-50 font-bold' : 'hover:bg-gray-50',
                getZoneColor(team.pos),
              ]}>
                <span class:list={[
                  'text-center font-bold text-xs flex items-center justify-center',
                  getPosColor(team.pos),
                ]}>
                  {team.pos}
                </span>
                <span class:list={[
                  'truncate',
                  isUs ? 'text-azzurro-600' : 'text-gray-900'
                ]}>
                  {team.squadra}
                </span>
                <span class:list={[
                  'text-center font-extrabold',
                  isUs ? 'text-azzurro-600' : 'text-gray-900'
                ]}>
                  {team.punti}
                </span>
                <span class="text-center text-gray-400 hidden md:block">{team.pg}</span>
                <span class="text-center text-green-600">{team.v}</span>
                <span class="text-center text-gray-400">{team.n}</span>
                <span class="text-center text-red-400">{team.p}</span>
                <span class="text-center text-gray-500 hidden md:block">{team.gf}</span>
                <span class="text-center text-gray-500 hidden md:block">{team.gs}</span>
              </div>
            );
          })}
        </div>

        <!-- Legenda zone -->
        <div class="flex flex-wrap gap-x-5 gap-y-1.5 mt-4 text-xs text-gray-500">
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-green-500"></span> Promozione</span>
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-azzurro-400"></span> Playoff</span>
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-orange-400"></span> Playout</span>
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm bg-red-500"></span> Retrocessione</span>
        </div>

        <p class="text-gray-400 text-xs mt-3 flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Aggiornata al {new Date(data.aggiornamento).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })} · Fonte: romagnasport.com
        </p>
      </div>

      <!-- Marcatori -->
      <div class="reveal">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-gradient-to-br from-oro-400 to-oro-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-oro-500/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <h2 class="font-heading font-extrabold text-2xl md:text-3xl text-gray-900 tracking-wide">Marcatori</h2>
            <p class="text-gray-400 text-sm">{data.marcatori.reduce((sum, m) => sum + m.gol, 0)} gol totali</p>
          </div>
        </div>

        <div class="space-y-2">
          {data.marcatori.map((m, i) => (
            <div class:list={[
              'flex items-center gap-3 p-3 rounded-xl border transition-all duration-200',
              i === 0 ? 'bg-oro-50 border-oro-200' : 'bg-[#fafbfc] border-gray-100 hover:bg-white hover:shadow-sm'
            ]}>
              <div class:list={[
                'w-8 h-8 rounded-lg flex items-center justify-center font-bold text-sm shrink-0',
                i === 0 ? 'bg-oro-500 text-white' : i < 3 ? 'bg-azzurro-100 text-azzurro-600' : 'bg-gray-100 text-gray-500'
              ]}>
                {i + 1}
              </div>
              <div class="flex-1 min-w-0">
                <p class:list={[
                  'font-semibold text-sm truncate',
                  i === 0 ? 'text-oro-700' : 'text-gray-900'
                ]}>
                  {m.nome}
                </p>
                {m.rigori && (
                  <p class="text-xs text-gray-400">di cui {m.rigori} su rigore</p>
                )}
              </div>
              <div class:list={[
                'font-heading font-extrabold text-lg shrink-0',
                i === 0 ? 'text-oro-600' : 'text-gray-900'
              ]}>
                {m.gol}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
