---
import PlayerCard from './PlayerCard.astro';
import StaffCard from './StaffCard.astro';
import type { Player, StaffMember } from '../lib/seasons';

interface Props {
  team: Player[];
  staff: StaffMember[];
}

const { team, staff } = Astro.props;

const portieri = team.filter(p => p.ruolo === 'Portiere');
const difensori = team.filter(p => p.ruolo === 'Difensore');
const centrocampisti = team.filter(p => p.ruolo === 'Centrocampista');
const attaccanti = team.filter(p => p.ruolo === 'Attaccante');

const ruoli = [
  { nome: 'Portieri', giocatori: portieri, colore: 'from-amber-400 to-amber-600', dot: 'bg-amber-500' },
  { nome: 'Difensori', giocatori: difensori, colore: 'from-emerald-400 to-emerald-600', dot: 'bg-emerald-500' },
  { nome: 'Centrocampisti', giocatori: centrocampisti, colore: 'from-azzurro-400 to-azzurro-600', dot: 'bg-azzurro-500' },
  { nome: 'Attaccanti', giocatori: attaccanti, colore: 'from-red-400 to-red-600', dot: 'bg-red-500' },
];
---

<!-- Giocatori per ruolo -->
{ruoli.map((gruppo, i) => (
  gruppo.giocatori.length > 0 && (
    <section class:list={['py-14', i % 2 === 0 ? 'bg-[#fafbfc]' : 'bg-white']}>
      <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-3 mb-8 reveal">
          <div class={`w-1 h-8 bg-gradient-to-b ${gruppo.colore} rounded-full`}></div>
          <h2 class="font-heading font-extrabold text-2xl md:text-3xl tracking-wide">{gruppo.nome}</h2>
          <span class="text-sm text-gray-300 font-medium ml-1">({gruppo.giocatori.length})</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 reveal stagger-children">
          {gruppo.giocatori.map(giocatore => (
            <PlayerCard {...giocatore} />
          ))}
        </div>
      </div>
    </section>
  )
))}

<!-- Staff Tecnico -->
{staff.length > 0 && (
  <section class="py-16 bg-white relative">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-8 reveal">
        <div class="w-10 h-10 bg-gradient-to-br from-azzurro-500 to-azzurro-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-azzurro-500/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <h2 class="font-heading font-extrabold text-2xl md:text-3xl tracking-wide">Staff Tecnico</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 reveal stagger-children">
        {staff.map(membro => (
          <StaffCard {...membro} />
        ))}
      </div>
    </div>
  </section>
)}

<!-- Empty state -->
{team.length === 0 && staff.length === 0 && (
  <section class="py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <div class="w-18 h-18 bg-gray-50 rounded-2xl flex items-center justify-center mx-auto mb-5 border border-gray-100">
        <svg class="w-9 h-9 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <h3 class="font-heading font-bold text-2xl text-gray-900 mb-3">Rosa in aggiornamento</h3>
      <p class="text-gray-400">La rosa verrà aggiornata presto. Seguici sui social per restare informato!</p>
    </div>
  </section>
)}
