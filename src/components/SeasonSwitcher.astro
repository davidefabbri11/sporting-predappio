---
import { getAllSeasons } from '../lib/seasons';
import type { SeasonEntry } from '../lib/seasons';

interface Props {
  currentSeasonId: string;
  /** Base URL path, e.g. "/rosa" or "/calendario" */
  basePath: string;
  /** The default (no-season) URL - when current season is clicked, go here */
  defaultPath?: string;
}

const { currentSeasonId, basePath, defaultPath } = Astro.props;
const seasons = getAllSeasons();

// Only show if more than 1 season
if (seasons.length <= 1) return;
---

<div class="flex flex-wrap items-center justify-center gap-2 mt-4 animate-fade-in" style="animation-delay: 200ms;">
  {seasons.map((season: SeasonEntry) => {
    const isActive = season.id === currentSeasonId;
    const href = defaultPath && isActive ? defaultPath : `${basePath}/${season.id}`;
    return (
      <a
        href={href}
        class:list={[
          'px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-300 border',
          isActive
            ? 'bg-white/20 text-white border-white/30 backdrop-blur-sm'
            : 'bg-white/5 text-azzurro-200/60 border-white/10 hover:bg-white/10 hover:text-white hover:border-white/20'
        ]}
      >
        {season.label}
      </a>
    );
  })}
</div>
