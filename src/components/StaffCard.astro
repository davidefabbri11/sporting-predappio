---
interface Props {
  nome: string;
  ruolo: string;
  tipo: string;
  foto?: string;
}

const { nome, ruolo, tipo, foto } = Astro.props;

const tipoIcon = tipo === 'dirigente'
  ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />'
  : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />';
---

<div class="group relative bg-white rounded-2xl border border-gray-100 p-4 flex items-center gap-4 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-gray-200/60 card-shimmer">
  <!-- Subtle accent -->
  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-azzurro-400/50 via-azzurro-500/50 to-oro-400/50"></div>

  {foto ? (
    <div class="relative">
      <img
        src={foto}
        alt={nome}
        class="w-14 h-14 rounded-xl object-cover object-top shrink-0 ring-2 ring-gray-100 group-hover:ring-azzurro-200 transition-all duration-300"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="w-14 h-14 bg-gradient-to-br from-azzurro-50 to-azzurro-100 rounded-xl flex items-center justify-center text-azzurro-500 shrink-0 border border-azzurro-100">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <Fragment set:html={tipoIcon} />
      </svg>
    </div>
  )}
  <div class="min-w-0">
    <p class="font-heading font-bold text-gray-900 truncate text-lg tracking-wide">{nome}</p>
    <p class="text-sm text-gray-400 font-medium">{ruolo}</p>
  </div>
</div>
