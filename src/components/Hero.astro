---
import { getCurrentSeasonId, getSeasonManifest } from '../lib/seasons';

interface Props {
  categoria?: string;
  girone?: string;
  stagione?: string;
}

const seasonId = getCurrentSeasonId();
const manifest = getSeasonManifest(seasonId);

const categoria = Astro.props.categoria ?? manifest?.primaSquadra.categoria ?? '';
const girone = Astro.props.girone ?? manifest?.primaSquadra.girone ?? '';
const stagione = Astro.props.stagione ?? manifest?.label ?? '';
---

<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden -mt-[72px]">
  <!-- Background photo -->
  <div class="absolute inset-0">
    <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover object-center" loading="eager" />
  </div>

  <!-- Dark overlay over photo -->
  <div class="absolute inset-0 bg-azzurro-950/70"></div>

  <!-- Animated mesh gradient overlay (semi-transparent) -->
  <div class="absolute inset-0 mesh-gradient opacity-40"></div>

  <!-- Radial overlay for depth -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,transparent_0%,rgba(8,37,54,0.5)_100%)]"></div>

  <!-- Floating geometric shapes -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -right-32 top-1/4 w-96 h-96 rounded-full border border-white/5 animate-float-slow"></div>
    <div class="absolute -left-20 bottom-1/4 w-72 h-72 rounded-full border border-azzurro-400/10 animate-float"></div>

    <div class="absolute right-1/4 top-1/3 w-64 h-64 bg-azzurro-400/10 rounded-full blur-[80px] animate-pulse-glow"></div>
    <div class="absolute left-1/4 bottom-1/3 w-48 h-48 bg-oro-400/10 rounded-full blur-[60px] animate-pulse-glow" style="animation-delay: 1.5s;"></div>

    <svg class="absolute inset-0 w-full h-full opacity-[0.03]" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="diag" width="60" height="60" patternUnits="userSpaceOnUse" patternTransform="rotate(35)">
          <line x1="0" y1="0" x2="0" y2="60" stroke="white" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#diag)" />
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-4 py-24 md:py-32 text-center">
    <!-- Logo with glow -->
    <div class="inline-block mb-8 animate-fade-in">
      <div class="relative">
        <div class="absolute inset-0 bg-azzurro-400/20 rounded-full blur-2xl scale-150"></div>
        <div class="relative w-32 h-32 md:w-36 md:h-36 mx-auto bg-white/10 backdrop-blur-sm rounded-full border border-white/20 p-4 shadow-2xl">
          <img src="/images/logo.png" alt="Sporting Predappio" class="w-full h-full object-contain drop-shadow-2xl" />
        </div>
      </div>
    </div>

    <h1 class="font-heading text-6xl sm:text-7xl md:text-8xl lg:text-9xl text-white mb-6 tracking-[0.15em] uppercase leading-[0.9] animate-fade-in-up" style="animation-delay: 150ms;">
      Sporting<br />
      <span class="text-gradient-gold">Predappio</span>
    </h1>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-4 animate-fade-in-up" style="animation-delay: 300ms;">
      <span class="px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-azzurro-100 text-sm font-medium border border-white/10">
        {categoria}
      </span>
      <span class="w-1.5 h-1.5 rounded-full bg-oro-400"></span>
      <span class="px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-azzurro-100 text-sm font-medium border border-white/10">
        {girone}
      </span>
    </div>

    <p class="text-azzurro-300/80 text-sm mb-2 animate-fade-in-up" style="animation-delay: 400ms;">
      Stagione {stagione}
    </p>

    <p class="font-heading text-oro-400 text-3xl md:text-4xl tracking-[0.3em] mb-10 animate-fade-in-up" style="animation-delay: 500ms;">
      #VIVILACONNOI
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up" style="animation-delay: 600ms;">
      <a href="/calendario" class="group inline-flex items-center justify-center gap-3 bg-white text-azzurro-900 font-bold px-8 py-4 rounded-2xl hover:shadow-xl hover:shadow-white/10 transition-all duration-300 hover:-translate-y-0.5">
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Calendario Partite
      </a>
      <a href="/rosa" class="group inline-flex items-center justify-center gap-3 border-2 border-white/30 text-white font-bold px-8 py-4 rounded-2xl hover:bg-white/10 hover:border-white/50 transition-all duration-300 hover:-translate-y-0.5 backdrop-blur-sm">
        <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        La Squadra
      </a>
    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0">
    <div class="h-px bg-gradient-to-r from-transparent via-azzurro-400/30 to-transparent"></div>
    <div class="h-24 bg-gradient-to-t from-[#fafbfc] to-transparent"></div>
  </div>
</section>
